#!/usr/bin/env bash
# GSBUILDER.AI — opens your project in gsbuilder.ai (CLI or macOS app) with brand assets
#
# CLI entry: all user-facing commands and flags are handled in main() below.
# Optional env: GSBUILDER_HOME, GSBUILDER_LOGO, GSBUILDER_EDITOR_BIN, GSBUILDER_EDITOR_APP
# (legacy: CURSOR_BIN, CURSOR_APP still honored if the GSBUILDER_* vars are unset).
set -euo pipefail

readonly BRAND_NAME="GSBUILDER.AI"
readonly VERSION="1.3.0"
readonly DEFAULT_EDITOR_APP="gsbuilder.ai"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

resolve_brand_dir() {
  if [[ -n "${GSBUILDER_HOME:-}" && -d "${GSBUILDER_HOME}/brand" ]]; then
    printf '%s' "${GSBUILDER_HOME}/brand"
    return 0
  fi
  # install.sh layout: PREFIX/bin/gsbuilder-ai + PREFIX/share/gsbuilder-ai/brand
  if [[ "$SCRIPT_DIR" == */bin ]]; then
    local prefix="${SCRIPT_DIR%/bin}"
    prefix="${prefix%/}"
    if [[ -d "$prefix/share/gsbuilder-ai/brand" ]]; then
      printf '%s' "$prefix/share/gsbuilder-ai/brand"
      return 0
    fi
  fi
  if [[ -d "$SCRIPT_DIR/brand" ]]; then
    printf '%s' "$SCRIPT_DIR/brand"
    return 0
  fi
  local d
  for d in "$HOME/.local/share/gsbuilder-ai/brand" "/opt/homebrew/share/gsbuilder-ai/brand" "/usr/local/share/gsbuilder-ai/brand"; do
    if [[ -d "$d" ]]; then
      printf '%s' "$d"
      return 0
    fi
  done
  printf '%s' "$SCRIPT_DIR/brand"
}

readonly BRAND_DIR="$(resolve_brand_dir)"

PROG="$(basename "$0")"

die() {
  printf '%s: %s\n' "$BRAND_NAME" "$*" >&2
  exit 1
}

resolve_logo() {
  if [[ -n "${GSBUILDER_LOGO:-}" && -r "$GSBUILDER_LOGO" ]]; then
    printf '%s' "$GSBUILDER_LOGO"
    return 0
  fi
  local f
  for f in "$BRAND_DIR/icon.svg" "$BRAND_DIR/logo.svg" "$BRAND_DIR/logo.png" "$BRAND_DIR/logo.webp"; do
    if [[ -r "$f" ]]; then
      printf '%s' "$f"
      return 0
    fi
  done
  return 1
}

banner_text() {
  printf '%s\n' "$BRAND_NAME"
}

usage() {
  local logo_line="(no logo file — add brand/icon.svg next to this script)"
  if p="$(resolve_logo 2>/dev/null)"; then
    logo_line="$p"
  fi
  cat <<EOF
$(banner_text) — project launcher

Logo: $logo_line
  Run \`$PROG logo\` to open the logo in your default viewer (macOS).

Usage: $PROG <command> [args]
       $PROG [path]              Open path in gsbuilder.ai (default: current directory)

Commands:
  open [dir]              Open directory in gsbuilder.ai (default: .)
  here                    Open current directory
  logo                    Open brand logo file (macOS: \`open\`; else print path)
  which                   Show editor CLI path if installed (\`gsbuilder.ai\` or legacy \`cursor\`)
  paths                   Show resolved script dir, brand dir, and editor CLI
  version                 Show $BRAND_NAME launcher version

Environment:
  GSBUILDER_HOME         Install root containing \`brand/\` (after ./install.sh)
  GSBUILDER_LOGO         Override path to logo image (svg/png/webp)
  GSBUILDER_EDITOR_APP   macOS app name or bundle (default: $DEFAULT_EDITOR_APP)
  GSBUILDER_EDITOR_BIN   Full path to editor CLI (optional)
  CURSOR_APP, CURSOR_BIN Legacy aliases for GSBUILDER_EDITOR_APP / GSBUILDER_EDITOR_BIN

Install (optional — copies into PREFIX/bin and PREFIX/share):
  ./install.sh --auto          # ~/.local by default
  make install                  # same as install.sh --auto

Run from a git clone without installing:
  ./gsbuilder-ai version
  ./gsbuilder.ai version   # same launcher (symlink in repo)
  ./gsbuilder-ai .

Examples:
  $PROG .
  $PROG open ~/projects/app
EOF
}

cmd_paths() {
  printf 'script:      %s\n' "${BASH_SOURCE[0]}"
  printf 'script_dir:  %s\n' "$SCRIPT_DIR"
  printf 'brand_dir:   %s\n' "$BRAND_DIR"
  printf 'editor_app:  %s\n' "${GSBUILDER_EDITOR_APP:-${CURSOR_APP:-$DEFAULT_EDITOR_APP}}"
  if bin="$(find_editor_cli 2>/dev/null)"; then
    printf 'editor CLI:  %s\n' "$bin"
  else
    printf 'editor CLI:  (not found — install shell command from gsbuilder.ai)\n'
  fi
}

find_editor_cli() {
  if [[ -n "${GSBUILDER_EDITOR_BIN:-}" && -x "$GSBUILDER_EDITOR_BIN" ]]; then
    printf '%s' "$GSBUILDER_EDITOR_BIN"
    return 0
  fi
  if [[ -n "${CURSOR_BIN:-}" && -x "$CURSOR_BIN" ]]; then
    printf '%s' "$CURSOR_BIN"
    return 0
  fi
  if command -v gsbuilder.ai >/dev/null 2>&1; then
    local g
    g="$(command -v gsbuilder.ai)"
    # Avoid exec recursion when gsbuilder.ai is a symlink to this launcher
    if [[ ! "$g" -ef "${BASH_SOURCE[0]}" ]]; then
      printf '%s' "$g"
      return 0
    fi
  fi
  if command -v cursor >/dev/null 2>&1; then
    command -v cursor
    return 0
  fi
  local p
  for p in /opt/homebrew/bin/gsbuilder.ai /usr/local/bin/gsbuilder.ai \
           /opt/homebrew/bin/cursor /usr/local/bin/cursor; do
    if [[ -x "$p" ]]; then
      printf '%s' "$p"
      return 0
    fi
  done
  return 1
}

cmd_logo() {
  local path
  if ! path="$(resolve_logo)"; then
    die "No logo found. Set GSBUILDER_LOGO or add ${BRAND_DIR}/icon.svg"
  fi
  if [[ "$(uname -s)" == "Darwin" ]]; then
    exec open "$path"
  fi
  printf '%s\n' "$path"
}

open_in_editor() {
  local target="${1:-.}"
  target="$(cd "$target" 2>/dev/null && pwd || true)"
  [[ -n "$target" ]] || die "not a directory: ${1:-.}"

  local bin
  if bin="$(find_editor_cli 2>/dev/null)"; then
    exec "$bin" "$target"
  fi

  if [[ "$(uname -s)" == "Darwin" ]]; then
    darwin_open_editor "$target"
  fi

  die "gsbuilder.ai CLI not found. In gsbuilder.ai: Command Palette → Shell Command: install editor command in PATH"
}

darwin_try_open_app() {
  local app="$1" target="$2"
  local bundle="/Applications/${app}.app"
  [[ -d "$bundle" ]] || bundle="$HOME/Applications/${app}.app"
  if [[ -d "$bundle" ]] && open -a "$bundle" "$target"; then
    return 0
  fi
  if open -a "$app" "$target" 2>/dev/null; then
    return 0
  fi
  return 1
}

darwin_open_editor() {
  local target="$1"
  local app="${GSBUILDER_EDITOR_APP:-${CURSOR_APP:-$DEFAULT_EDITOR_APP}}"
  if darwin_try_open_app "$app" "$target"; then
    exit 0
  fi
  # If default branding app is missing, fall back to Cursor when user did not override app name
  if [[ "$app" == "$DEFAULT_EDITOR_APP" ]] && [[ -z "${GSBUILDER_EDITOR_APP:-}${CURSOR_APP:-}" ]]; then
    if darwin_try_open_app "Cursor" "$target"; then
      printf '%s: opened Cursor as fallback (install %s.app or set GSBUILDER_EDITOR_APP)\n' \
        "$BRAND_NAME" "$DEFAULT_EDITOR_APP" >&2
      exit 0
    fi
  fi
  die "Could not open editor app \"$app\". Install the app or set GSBUILDER_EDITOR_APP / GSBUILDER_EDITOR_BIN"
}

cmd_which() {
  if bin="$(find_editor_cli 2>/dev/null)"; then
    printf '%s\n' "$bin"
  else
    die "editor CLI not on PATH (set GSBUILDER_EDITOR_BIN or install shell command from gsbuilder.ai)"
  fi
}

main() {
  case "${1:-}" in
    -h|--help|help)
      usage
      ;;
    -v|--version|version)
      printf '%s launcher %s\n' "$BRAND_NAME" "$VERSION"
      ;;
    open)
      shift
      open_in_editor "${1:-.}"
      ;;
    here)
      open_in_editor "."
      ;;
    logo)
      cmd_logo
      ;;
    which)
      cmd_which
      ;;
    paths)
      cmd_paths
      ;;
    "")
      open_in_editor "."
      ;;
    *)
      if [[ "$1" == -* ]]; then
        die "unknown option: $1 (try --help)"
      fi
      open_in_editor "$1"
      ;;
  esac
}

main "$@"
